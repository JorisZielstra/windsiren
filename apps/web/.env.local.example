# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase — values from your project dashboard:
# Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# KNMI — register at https://developer.dataplatform.knmi.nl/apis
# v0.1 compromise: this key ships in the client bundle. KNMI rate-limits to
# 1000 req/hour; if abused, rotate the key in KNMI dashboard. v0.2 will move
# live-observation fetches behind a Supabase Edge Function proxy.
NEXT_PUBLIC_KNMI_API_KEY=REPLACE_ME

# Forecast model — Open-Meteo's KNMI HARMONIE-AROME (NL high-res 2 km grid)
# is the default and needs no API key. Override only if you've migrated
# to Open-Meteo's commercial endpoint or want to force `best_match`.
# WEATHER_MODEL=knmi_harmonie_arome_netherlands
